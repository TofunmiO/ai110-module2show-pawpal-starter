classDiagram
    class Owner {
        +String name
        +int time_available
        +List preferences
        +List~Pet~ pets
        +add_pet(pet)
        +all_tasks()
    }

    class Pet {
        +String name
        +String animal_type
        +List~Task~ tasks
        +add_task(task)
    }

    class Task {
        +String name
        +int duration
        +int priority
        +String frequency
        +bool is_required
        +bool completed
        +Pet pet
        +fits_in(remaining_minutes)
        +mark_done()
    }

    class Scheduler {
        +Owner owner
        +int start_hour
        +List entries
        +List~Task~ skipped
        +String reasoning
        +sort_tasks()
        +generate_daily_plan()
        +explain()
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" Task : contains
    Task "0..*" --> "1" Pet : belongs to
    Scheduler --> Owner : plans for
